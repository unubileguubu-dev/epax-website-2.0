{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/shell.html"
    }
  ],
  "headers": [
    {
      "source": "/:file(main-[A-Z0-9]+\\.js|styles-[A-Z0-9]+\\.css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
